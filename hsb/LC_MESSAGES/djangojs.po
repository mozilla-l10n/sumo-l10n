msgstr "Forumy pomocy"

#: svelte/contribute/Contribute.svelte:63 svelte/contribute/Contribute.svelte:117 svelte/contribute/Contribute.svelte:173
msgid "Learn the basic guidelines"
msgstr "Wukńće zakładne směrnicy"

#: svelte/contribute/Contribute.svelte:70
