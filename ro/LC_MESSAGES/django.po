#: kitsune/kpi/jinja2/kpi/dashboard.html:27
msgid "Questions solved"
msgstr "Întrebări rezolvate"

#: kitsune/kpi/jinja2/kpi/dashboard.html:28
msgid "Definition: Percentage of threads that have answer marked as a solution"
