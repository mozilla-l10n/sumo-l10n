msgstr "Deschide"

#. This is a support ticket status, which means the ticket is awaiting a response
#. from the customer.
#: kitsune/customercare/models.py:103
msgctxt "ticket"
msgid "Pending"
msgstr "În așteptare"

#. This is a support ticket status, which means the ticket is awaiting a response
#. from a third party.
#: kitsune/customercare/models.py:105
msgid "Hold"
msgstr "Așteaptă"

